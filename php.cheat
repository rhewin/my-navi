fmod(7, 2)    // 1.0 (float modulo)
M_PI          // 3.14159...
PHP_INT_MAX
PHP_FLOAT_MAX

# PHP: random
rand(<min>, <max>)
mt_rand(<min>, <max>)                     // faster Mersenne Twister
random_int(<min>, <max>)                  // cryptographically secure
shuffle($arr)                             // in-place shuffle
array_rand($arr)                          // random key
array_rand($arr, <n>)                     // n random keys

# PHP: UUID v4 (no ext)
function uuid4(): string {
    $data = random_bytes(16);
    $data[6] = chr(ord($data[6]) & 0x0f | 0x40);
    $data[8] = chr(ord($data[8]) & 0x3f | 0x80);
    return vsprintf("%s%s-%s-%s-%s-%s%s%s", str_split(bin2hex($data), 4));
}

# PHP: hashing (passwords)
$hash   = password_hash($password, PASSWORD_BCRYPT, ["cost" => 12]);
$hash   = password_hash($password, PASSWORD_ARGON2ID);
$valid  = password_verify($password, $hash);
$rehash = password_needs_rehash($hash, PASSWORD_BCRYPT, ["cost" => 12]);

# PHP: serialization
$s = serialize($data);
$d = unserialize($s);  // WARNING: never unserialize untrusted input

# PHP: sleep / performance
usleep(500000);           // 500ms (microseconds)
sleep(1);                 // 1 second
$start = microtime(true);
// ... code ...
$elapsed = microtime(true) - $start;

# PHP: output buffering
ob_start();
// ... echo / print ...
$content = ob_get_clean();

