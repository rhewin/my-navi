$ method: echo "find save delete validate"
$ args: echo "int \$id string \$name"
$ returnType: echo "string int bool void ?User"

; ─────────────────────────────────────────────
; ERROR HANDLING & EXCEPTIONS
; ─────────────────────────────────────────────

% php, error, exception, try, catch, throw, handling

# PHP: try / catch / finally
try {
    $result = riskyOperation();
} catch (\InvalidArgumentException $e) {
    // handle specific
    log_error($e->getMessage());
} catch (\RuntimeException|\LogicException $e) {
    // multiple types (PHP 8+)
} catch (\Throwable $e) {
    // catch all errors and exceptions
} finally {
    // always runs (cleanup)
}

# PHP: throw expression (PHP 8.0+)
$val = $input ?? throw new \InvalidArgumentException("input required");
$user = $this->find($id) ?? throw new NotFoundException("User $id not found");

# PHP: custom exception
class DomainException extends \RuntimeException {
    public function __construct(
        string $message,
        private readonly string $context = "",
        int $code = 0,
        ?\Throwable $previous = null,
    ) {
        parent::__construct($message, $code, $previous);
    }

    public function getContext(): string {
        return $this->context;
    }
}

// Throw:
throw new DomainException("Invalid state", context: "checkout");

# PHP: exception hierarchy
\Throwable
├── \Error          (fatal PHP errors)
│   ├── \TypeError
│   ├── \ValueError
│   ├── \ArithmeticError
│   └── \ParseError
└── \Exception
    ├── \RuntimeException
    ├── \LogicException
    ├── \InvalidArgumentException
    └── \BadMethodCallException

# PHP: set global error / exception handler
set_exception_handler(function (\Throwable $e) {
    error_log($e->getMessage());
    http_response_code(500);
    exit(1);
});

set_error_handler(function (int $errno, string $errstr, string $file, int $line): bool {
    throw new \ErrorException($errstr, 0, $errno, $file, $line);
});

; ─────────────────────────────────────────────
; JSON
; ─────────────────────────────────────────────

% php, json, encode, decode, serialize

# PHP: json decode
json_decode(<json>, true)          // → assoc array (true = array, false = object)
json_decode($json, true, 512, JSON_THROW_ON_ERROR)  // throws \JsonException

# PHP: json encode
json_encode(<data>)
json_encode($data, JSON_PRETTY_PRINT)
json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES)
json_encode($data, JSON_THROW_ON_ERROR)  // throws \JsonException on error

# PHP: json error handling (safe pattern)
try {
    $data = json_decode($json, true, 512, JSON_THROW_ON_ERROR);
    $out  = json_encode($data, JSON_THROW_ON_ERROR);
} catch (\JsonException $e) {
    // handle malformed json
}

# PHP: json check legacy (pre PHP 7.3)
$data = json_decode($json, true);
if (json_last_error() !== JSON_ERROR_NONE) {
    throw new \RuntimeException(json_last_error_msg());
}

$ json: echo '\'{"key":"value"}\' $response $body'
$ data: echo '$user $arr $result'

; ─────────────────────────────────────────────
; DATABASE / PDO
; ─────────────────────────────────────────────

% php, database, pdo, mysql, postgres, sql, query

# PHP: PDO connect (preferred over mysqli)
$pdo = new \PDO(
    "mysql:host=<host>;dbname=<db>;charset=utf8mb4",
    "<user>",
    "<pass>",
    [
        \PDO::ATTR_ERRMODE            => \PDO::ERRMODE_EXCEPTION,
        \PDO::ATTR_DEFAULT_FETCH_MODE => \PDO::FETCH_ASSOC,
        \PDO::ATTR_EMULATE_PREPARES   => false,
    ]
);

# PHP: PDO - query single row
$stmt = $pdo->prepare("SELECT * FROM users WHERE id = :id");
$stmt->execute(["id" => $id]);
$user = $stmt->fetch();           // assoc array or false
$user = $stmt->fetchObject(User::class);  // hydrate object

# PHP: PDO - query multiple rows
$stmt = $pdo->prepare("SELECT * FROM users WHERE active = :active");
$stmt->execute(["active" => 1]);
$users = $stmt->fetchAll();                        // all rows
$users = $stmt->fetchAll(\PDO::FETCH_ASSOC);
$users = $stmt->fetchAll(\PDO::FETCH_CLASS, User::class);
$col   = $stmt->fetchAll(\PDO::FETCH_COLUMN);     // first column only

# PHP: PDO - insert / update / delete
$stmt = $pdo->prepare(
    "INSERT INTO users (name, email) VALUES (:name, :email)"
);
$stmt->execute(["name" => $name, "email" => $email]);
$id       = $pdo->lastInsertId();
$affected = $stmt->rowCount();

# PHP: PDO - transaction
try {
    $pdo->beginTransaction();
    $pdo->prepare("UPDATE accounts SET balance = balance - :amount WHERE id = :id")
        ->execute(["amount" => $amount, "id" => $fromId]);
    $pdo->prepare("UPDATE accounts SET balance = balance + :amount WHERE id = :id")
        ->execute(["amount" => $amount, "id" => $toId]);
    $pdo->commit();
} catch (\Throwable $e) {
    $pdo->rollBack();
    throw $e;
}

# PHP: connect mysqli (legacy)
$conn = new mysqli(<host>, <user>, <password>, <db>);
if ($conn->connect_error) {
    throw new \RuntimeException($conn->connect_error);
}
$conn->set_charset("utf8mb4");

# PHP: mysqli - prepared statement
$stmt = $conn->prepare("SELECT id, name FROM users WHERE email = ?");
$stmt->bind_param("s", $email);   // s=string i=int d=double b=blob
$stmt->execute();
$result = $stmt->get_result();
while ($row = $result->fetch_assoc()) {
    // use $row
}
$stmt->close();
$conn->close();

