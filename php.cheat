; ─────────────────────────────────────────────

% php, test, phpunit, unit, testing, mock, assert

# PHP: basic test class
use PHPUnit\Framework\TestCase;

class UserServiceTest extends TestCase {
    public function test_creates_user(): void {
        $svc  = new UserService();
        $user = $svc->create("Alice", "alice@example.com");

        $this->assertInstanceOf(User::class, $user);
        $this->assertSame("Alice", $user->name);
    }
}

# PHP: PHPUnit - common assertions
$this->assertEquals($expected, $actual)
$this->assertSame($expected, $actual)          // strict ===
$this->assertTrue($val)
$this->assertFalse($val)
$this->assertNull($val)
$this->assertNotNull($val)
$this->assertCount(3, $arr)
$this->assertEmpty($arr)
$this->assertContains($needle, $haystack)
$this->assertArrayHasKey("key", $arr)
$this->assertStringContainsString("foo", $str)
$this->assertMatchesRegularExpression("/\d+/", $str)
$this->expectException(\InvalidArgumentException::class)
$this->expectExceptionMessage("invalid input")

# PHP: data provider (table-driven tests)
#[DataProvider("additionProvider")]
public function test_add(int $a, int $b, int $expected): void {
    $this->assertSame($expected, add($a, $b));
}

public static function additionProvider(): array {
    return [
        "positive" => [2, 3, 5],
        "negative" => [-1, -2, -3],
        "zero"     => [0, 0, 0],
    ];
}

