% php, common, basics

; ─────────────────────────────────────────────
; VARIABLES & TYPES
; ─────────────────────────────────────────────

% php, variables, types, declaration, basics

# PHP: variable declaration
$name = "Alice";
$age  = 30;
$pi   = 3.14;
$flag = true;
$nothing = null;

# PHP: type checking
gettype($var)           // "integer" "double" "string" "boolean" "array" "object" "NULL"
is_int($var)
is_float($var)
is_string($var)
is_bool($var)
is_null($var)
is_array($var)
is_object($var)
is_numeric("42")        // true for "42", "3.14", etc.

# PHP: type casting
(int)    "42"           // 42
(float)  "3.14"         // 3.14
(string) 42             // "42"
(bool)   0              // false
(array)  $value         // wrap in array

intval("42", <base>)    // base 10 default; intval("0xFF", 16)
floatval("3.14")
strval(42)
settype($var, "integer")  // in-place cast

# PHP: null coalescing
$val = $arr["key"] ?? "default";          // no notice if key missing
$val = $a ?? $b ?? $c ?? "fallback";      // chain
$arr["key"] ??= "default";               // assign if null (PHP 7.4+)

# PHP: constants
define("MAX_SIZE", 100);
const VERSION = "1.0.0";
defined("MAX_SIZE")  // check if defined

$ base: echo "2 8 10 16"

; ─────────────────────────────────────────────
; TYPE CONVERSION
; ─────────────────────────────────────────────

% php, conversion, cast, type, number, string

# PHP: int ↔ string
$s = (string) 42;
$s = strval(42);
$s = number_format(1234567.891, 2, ".", ",");  // "1,234,567.89"
$n = (int) "42abc";    // 42 (stops at non-numeric)
$n = intval("42");

# PHP: float ↔ string
$s = (string) 3.14;
$s = number_format(3.14159, 2);   // "3.14"
$s = sprintf("%.4f", 3.14159);    // "3.1416"
$f = (float) "3.14";
$f = floatval("3.14abc");         // 3.14

# PHP: int ↔ other bases
$hex  = dechex(255);              // "ff"
$oct  = decoct(8);                // "10"
$bin  = decbin(42);               // "101010"
$n    = hexdec("ff");             // 255
$n    = octdec("10");             // 8
$n    = bindec("101010");         // 42
$hex  = sprintf("%08X", 255);     // "000000FF"

# PHP: number formatting
number_format(<number>, <decimals>, ".", ",")   // e.g. "1,234.56"
money_format is deprecated — use NumberFormatter (intl ext)

# PHP: bool ↔ string / int
$s = $flag ? "true" : "false";
$b = (bool) "false";   // WARNING: true — any non-empty string is true
$b = filter_var("false", FILTER_VALIDATE_BOOLEAN);  // actual false

# PHP: char ↔ int (ASCII)
$char = chr(65);      // "A"
$code = ord("A");     // 65

$ number: echo "1234567.891 3.14159 0.5"
$ decimals: echo "0 2 4"

; ─────────────────────────────────────────────
; STRING MANIPULATION
; ─────────────────────────────────────────────

% php, string, strings, manipulation, text

# PHP: explode / implode
explode(<delimiter>, <string>)
explode(<delimiter>, <string>, <limit>)   // max <limit> elements
implode(<delimiter>, <array>)
str_split($str, <length>)                 // split into chunks of length

# PHP: length / search / position
strlen($str)
mb_strlen($str)                           // multibyte-safe
strpos($str, "<needle>")                  // false if not found
strrpos($str, "<needle>")                 // last occurrence
str_contains($str, "<needle>")            // PHP 8.0+
str_starts_with($str, "<prefix>")         // PHP 8.0+
str_ends_with($str, "<suffix>")           // PHP 8.0+
substr_count($str, "<needle>")

# PHP: substring
substr($str, <start>)                     // from start to end
substr($str, <start>, <length>)           // start + length
mb_substr($str, <start>, <length>)        // multibyte-safe

# PHP: replace
str_replace("<search>", "<replace>", $str)
str_ireplace("<search>", "<replace>", $str)  // case-insensitive
str_replace(["a","b"], ["1","2"], $str)       // multiple pairs
substr_replace($str, "<replace>", <start>, <length>)

# PHP: trim / pad
trim($str)                         // both ends
ltrim($str); rtrim($str)           // left / right
trim($str, "<chars>")              // custom chars
str_pad($str, <length>)            // right-pad with spaces
str_pad($str, <length>, "<pad>", STR_PAD_LEFT)
str_pad($str, <length>, "<pad>", STR_PAD_BOTH)

# PHP: case
strtolower($str); strtoupper($str)
ucfirst($str)                      // capitalize first char
lcfirst($str)
ucwords($str)                      // capitalize each word
mb_strtolower($str)                // multibyte-safe

# PHP: repeat / reverse / wrap
str_repeat("<str>", <times>)
strrev($str)
wordwrap($str, 75, "\n", true)

# PHP: sprintf formatting
sprintf("%d", 42)
sprintf("%.2f", 3.14159)         // "3.14"
sprintf("%05d", 42)              // "00042"
sprintf("%-10s|", "left")        // "left      |"
sprintf("%010.2f", 3.14)         // "0000003.14"
sprintf("%s has %d items", $name, $count)

# PHP: heredoc / nowdoc
$html = <<<EOT
    <p>Hello, {$name}</p>
EOT;

$raw = <<<'EOT'
    No $variable interpolation here
EOT;

# PHP: string comparison
strcmp($a, $b)          // 0 if equal, <0 / >0 otherwise
strcasecmp($a, $b)      // case-insensitive
similar_text($a, $b, $percent)
levenshtein($a, $b)
soundex($str); metaphone($str)

# PHP: hash / encryption
md5($str)
sha1($str)
hash("<algo>", $str)               // "sha256", "sha512", etc.
password_hash($plain, PASSWORD_BCRYPT)
password_verify($plain, $hash)

$ delimiter: echo "',' ' ' ':' '|' PHP_EOL"
$ needle: echo "'foo' 'bar' 'http'"
$ prefix: echo "'https' 'user_' '/api'"
$ suffix: echo "'.php' '.html' '_id'"
$ length: echo "10 20 50 100"
$ pad: echo "'0' ' ' '-' '*'"
$ times: echo "3 5 10"
$ algo: echo "sha256 sha512 md5"

; ─────────────────────────────────────────────
; ARRAY OPERATIONS
; ─────────────────────────────────────────────

% php, array, list, collection, map

# PHP: create array
$arr = [1, 2, 3];
$arr = ["key" => "value", "foo" => "bar"];
$arr = array_fill(0, <count>, <value>);    // fill with value
$arr = range(1, 10);                       // [1..10]
$arr = range(1, 10, 2);                    // [1,3,5,7,9]

# PHP: add / remove
$arr[] = $val;                             // append
array_push($arr, $val);                    // append (multiple ok)
array_unshift($arr, $val);                 // prepend
$last   = array_pop($arr);                 // remove + return last
$first  = array_shift($arr);               // remove + return first
array_splice($arr, <offset>, <length>);    // remove range
unset($arr[<key>]);                        // remove by key (preserves keys)

# PHP: search
in_array(<value>, $arr)                    // loose comparison
in_array(<value>, $arr, true)             // strict (===)
array_search(<value>, $arr)               // returns key or false
array_key_exists(<key>, $arr)
isset($arr[<key>])                         // also false if value is null

# PHP: filter / map / reduce
array_filter(<array>, fn($x) => <condition>)
array_filter($arr)                         // remove falsy values
array_map(fn($x) => <code>, <array>)
array_map(fn($a, $b) => $a + $b, $arr1, $arr2)  // multiple arrays
array_reduce($arr, fn($carry, $item) => $carry + $item, 0)

# PHP: sort
sort($arr)                // sort values, reindex
rsort($arr)               // reverse sort values
asort($arr)               // sort values, keep keys
arsort($arr)              // reverse, keep keys
ksort($arr)               // sort by key
krsort($arr)              // reverse sort by key
usort($arr, fn($a, $b) => $a <=> $b)       // custom compare (spaceship op)
uasort($arr, fn($a, $b) => $a <=> $b)     // custom, keep keys
uksort($arr, fn($a, $b) => strcmp($a, $b)) // custom, sort by key

# PHP: slice / splice / chunk
array_slice($arr, <offset>, <length>)
array_slice($arr, <offset>, <length>, true) // preserve keys
array_chunk($arr, <size>)                  // split into chunks
array_chunk($arr, <size>, true)            // preserve keys

# PHP: merge / combine / diff
array_merge($a, $b)                        // numeric keys reindexed
array_replace($a, $b)                      // $b overwrites $a
$combined = array_combine($keys, $values)  // keys[] + values[] → assoc
array_diff($a, $b)                         // values in $a not in $b
array_diff_key($a, $b)                     // keys in $a not in $b
array_intersect($a, $b)                    // values in both
array_intersect_key($a, $b)                // keys in both

# PHP: transform
array_keys($arr)
array_values($arr)                         // re-index to 0..n
array_flip($arr)                           // swap keys ↔ values
array_unique($arr)                         // remove duplicates
array_reverse($arr)
array_column($records, "<col>")            // pluck column from 2D array
array_column($records, "<col>", "<key>")   // indexed by key column

# PHP: count / stats
count($arr)
array_sum($arr)
array_product($arr)
max($arr); min($arr)
array_count_values($arr)  // frequency map

# PHP: flatten
array_merge(...$nested)                    // one level
// recursive flatten:
function flatten(array $arr): array {
    return array_merge(...array_map(
        fn($v) => is_array($v) ? flatten($v) : [$v], $arr
    ));
}

# PHP: walk
array_walk($arr, function(&$val, $key) {
    $val = strtoupper($val);
});

$ count: echo "5 10 100"
$ value: echo "0 null '' 'default'"
$ offset: echo "0 1 2 -1"
$ length: echo "1 3 10 null"
$ size: echo "3 5 10"
$ col: echo "'name' 'id' 'email'"
$ key: echo "'id' 'slug' 'uuid'"

; ─────────────────────────────────────────────
; CONTROL FLOW
; ─────────────────────────────────────────────

% php, control-flow, if, loop, match, foreach

# PHP: match expression (PHP 8.0+)
$result = match(<expr>) {
    1, 2    => "one or two",
    3       => "three",
    default => "other",
};
// strict comparison (===), no fallthrough, exhaustive

# PHP: match with no-match exception
// Throws \UnhandledMatchError if no arm matches and no default

# PHP: foreach
foreach ($arr as $val) { }
foreach ($arr as $key => $val) { }
foreach ($arr as &$val) { $val *= 2; }  // by reference
unset($val);  // IMPORTANT: break reference after loop

# PHP: for / while / do-while
for ($i = 0; $i < <n>; $i++) { }
while (<condition>) { }
do { } while (<condition>);

# PHP: break / continue with levels
foreach ($outer as $a) {
    foreach ($inner as $b) {
        if ($b === 0) continue 2;  // continue outer loop
        if ($a === 0) break 2;     // break both loops
    }
}

# PHP: list() / [] destructuring
[$a, $b, $c] = [1, 2, 3];
[, $second] = [1, 2, 3];                      // skip first
["name" => $name, "age" => $age] = $person;   // key destructuring
[$first, ...$rest] = $arr;                    // spread (not native, use array_slice)

$ expr: echo "$status $code $type"
$ n: echo "10 100 count(\$arr)"
$ condition: echo "!empty(\$queue) \$i < \$max"

; ─────────────────────────────────────────────
; FUNCTIONS
; ─────────────────────────────────────────────

% php, function, callable, closure, arrow, higher-order

# PHP: function declaration
function <name>(<arg1>, <arg2> = <default>): <returnType> {
    return <value>;
}

# PHP: typed parameters + return (PHP 8+)
function add(int $a, int $b): int {
    return $a + $b;
}

function maybeNull(?string $s): ?string {
    return $s ? strtoupper($s) : null;
}

# PHP: union types (PHP 8.0+)
function process(int|string $id): User|null { }

# PHP: named arguments (PHP 8.0+)
htmlspecialchars(string: $s, double_encode: false);
array_slice(array: $arr, offset: 0, length: 5, preserve_keys: true);

# PHP: variadic functions
function sum(int ...$nums): int {
    return array_sum($nums);
}
sum(1, 2, 3);
sum(...$arr);  // spread array as args

# PHP: closure / anonymous function
$fn = function($x) use ($factor) {
    return $x * $factor;
};

# PHP: arrow function (PHP 7.4+) — auto-captures outer scope
$fn = fn($x) => $x * $factor;
$doubled = array_map(fn($x) => $x * 2, $arr);

# PHP: first-class callable (PHP 8.1+)
$fn = strlen(...);           // create closure from builtin
$fn = $obj->method(...);     // from method
$arr = array_map(strtoupper(...), $arr);

# PHP: callable types
call_user_func($callable, $arg1, $arg2);
call_user_func_array($callable, $args);
is_callable($var);

$ name: echo "calculate process validate transform"
$ arg1: echo "string \$name int \$id array \$data"
$ default: echo "null [] '' 0 true"
$ returnType: echo "string int bool array void mixed"

; ─────────────────────────────────────────────
; OOP
; ─────────────────────────────────────────────

% php, oop, class, object, interface, trait, extends

# PHP: class definition
class <Name> {
    public string $name;
    protected int $age;
    private array $data = [];

    public function __construct(string $name, int $age) {
        $this->name = $name;
        $this->age  = $age;
    }

    public function getName(): string {
        return $this->name;
    }
}

# PHP: constructor property promotion (PHP 8.0+)
class User {
    public function __construct(
        public readonly int    $id,
        public string          $name,
        protected ?string      $email = null,
    ) {}
}

# PHP: readonly properties (PHP 8.1+)
class Point {
    public function __construct(
        public readonly float $x,
        public readonly float $y,
    ) {}
}

# PHP: interface
interface <Name> {
    public function <method>(<args>): <returnType>;
}

class MyClass implements <Name> {
    public function <method>(<args>): <returnType> { }
}

# PHP: abstract class
abstract class BaseRepository {
    abstract public function find(int $id): ?object;

    public function findOrFail(int $id): object {
        return $this->find($id) ?? throw new \RuntimeException("Not found: $id");
    }
}

# PHP: trait
trait Timestamps {
    private \DateTime $createdAt;
    private \DateTime $updatedAt;

    public function touch(): void {
        $this->updatedAt = new \DateTime();
    }
}

class Post {
    use Timestamps;
}

# PHP: static methods and properties
class Counter {
    private static int $count = 0;

    public static function increment(): void {
        self::$count++;
    }

    public static function get(): int {
        return static::$count;  // late static binding
    }
}

Counter::increment();
Counter::get();

# PHP: magic methods
__construct()   // instantiation
__destruct()    // cleanup
__toString()    // string cast
__invoke()      // called as function: $obj()
__get($name)    // read inaccessible property
__set($name, $value)
__isset($name)
__unset($name)
__clone()       // after clone

# PHP: cloning and comparison
$copy = clone $obj;          // shallow clone
$a == $b    // same property values (loose)
$a === $b   // same instance

# PHP: enum (PHP 8.1+)
enum Status {
    case Active;
    case Inactive;
    case Pending;
}

enum Color: string {
    case Red   = "red";
    case Green = "green";
    case Blue  = "blue";

    public function label(): string {
        return ucfirst($this->value);
    }
}

$s = Status::Active;
$c = Color::from("red");          // throws ValueError if invalid
$c = Color::tryFrom("unknown");   // null if invalid
Color::cases();                   // array of all cases

