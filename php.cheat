$ pass: echo "secret password"

; ─────────────────────────────────────────────
; HTTP / REQUEST / RESPONSE
; ─────────────────────────────────────────────

% php, http, request, response, header, session, cookie

# PHP: superglobals
$_GET["key"]          // URL query params
$_POST["key"]         // POST form data
$_REQUEST["key"]      // GET + POST + COOKIE
$_FILES["file"]       // uploaded files
$_SERVER["key"]       // server + request info
$_ENV["key"]          // environment variables
$_SESSION["key"]      // session data
$_COOKIE["key"]       // cookies

# PHP: request method + headers
$method     = $_SERVER["REQUEST_METHOD"];      // GET POST PUT etc.
$uri        = $_SERVER["REQUEST_URI"];
$remoteAddr = $_SERVER["REMOTE_ADDR"];
$host       = $_SERVER["HTTP_HOST"];
$userAgent  = $_SERVER["HTTP_USER_AGENT"];
$contentType = $_SERVER["CONTENT_TYPE"] ?? "";

// Read raw body (for JSON APIs)
$body = file_get_contents("php://input");
$data = json_decode($body, true, 512, JSON_THROW_ON_ERROR);

# PHP: send headers and response
header("Content-Type: application/json");
header("Location: /login", true, 302);
header("Cache-Control: no-cache, must-revalidate");
http_response_code(201);

// JSON response helper
function jsonResponse(mixed $data, int $status = 200): never {
    http_response_code($status);
    header("Content-Type: application/json");
    echo json_encode($data, JSON_THROW_ON_ERROR);
    exit;
}

# PHP: session
session_start();
$_SESSION["user_id"] = $userId;
$val = $_SESSION["user_id"] ?? null;
unset($_SESSION["user_id"]);
session_destroy();                   // destroy all session data
session_regenerate_id(true);         // prevent session fixation

# PHP: cookies
setcookie("name", "value", time() + 3600, "/");
setcookie("name", "", time() - 1);  // delete cookie
// Secure cookie:
setcookie("token", $token, [
    "expires"  => time() + 86400,
    "path"     => "/",
    "secure"   => true,
    "httponly" => true,
    "samesite" => "Strict",
]);

# PHP: input validation / sanitization
$id    = filter_input(INPUT_GET,  "id",    FILTER_VALIDATE_INT);
$email = filter_input(INPUT_POST, "email", FILTER_VALIDATE_EMAIL);
$url   = filter_input(INPUT_POST, "url",   FILTER_VALIDATE_URL);
$safe  = filter_input(INPUT_POST, "name",  FILTER_SANITIZE_SPECIAL_CHARS);

// Manual:
$id    = (int) ($_GET["id"] ?? 0);
$email = filter_var($email, FILTER_VALIDATE_EMAIL);
$safe  = htmlspecialchars($input, ENT_QUOTES, "UTF-8");
$safe  = strip_tags($input);

; ─────────────────────────────────────────────
; FILE I/O
; ─────────────────────────────────────────────

% php, file, filesystem, io, read, write, directory

# PHP: read / write entire file
$contents = file_get_contents("<path>");
file_put_contents("<path>", $contents);
file_put_contents("<path>", $data, FILE_APPEND | LOCK_EX);

# PHP: read file as lines array
$lines = file("<path>", FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);

# PHP: open file handle
$fh = fopen("<path>", "<mode>");   // r r+ w w+ a a+ x
while (!feof($fh)) {
    $line = fgets($fh);
}
fwrite($fh, "content");
fclose($fh);

# PHP: CSV read / write
$fh = fopen("data.csv", "r");
while (($row = fgetcsv($fh, 0, ",")) !== false) {
    [$col1, $col2] = $row;
}
fclose($fh);

$fh = fopen("out.csv", "w");
fputcsv($fh, ["name", "age", "email"]);
fputcsv($fh, [$name, $age, $email]);
fclose($fh);

# PHP: file info / existence
file_exists("<path>")
is_file("<path>")
is_dir("<path>")
is_readable("<path>")
is_writable("<path>")
filesize("<path>")
filemtime("<path>")          // last modified timestamp
pathinfo("<path>")           // array: dirname, basename, extension, filename
pathinfo("<path>", PATHINFO_EXTENSION)
basename("<path>")
dirname("<path>")
realpath("<path>")           // resolve symlinks + ..

# PHP: copy / move / delete
copy("src.txt", "dst.txt")
rename("old.txt", "new.txt")   // also works as move
unlink("<path>")               // delete file
mkdir("<dir>", 0755, true)     // recursive mkdir -p
rmdir("<dir>")                 // remove empty dir

# PHP: directory listing
$files = scandir("<dir>");
$files = array_diff(scandir("<dir>"), [".", ".."]);  // skip . and ..

// Glob
$phpFiles = glob("<dir>/*.php");
$all      = glob("<dir>/**/*", GLOB_BRACE);

// RecursiveIterator
$iter = new \RecursiveIteratorIterator(
    new \RecursiveDirectoryIterator("<dir>", \FilesystemIterator::SKIP_DOTS)
);
foreach ($iter as $file) {
    echo $file->getPathname();
}

# PHP: temp file
$tmp = tempnam(sys_get_temp_dir(), "prefix_");
register_shutdown_function("unlink", $tmp);

$ path: echo "'/var/www/data.json' 'config.php' '/tmp/output.csv'"
$ mode: echo "r r+ w w+ a a+"
$ dir: echo "'/var/www/uploads' './storage' '/tmp'"

; ─────────────────────────────────────────────
; REGEX
; ─────────────────────────────────────────────

% php, regex, regexp, preg, pattern, match

# PHP: regex test / match
preg_match("/<pattern>/", $subject)                  // 1 if match, 0 if not
preg_match("/<pattern>/", $subject, $matches)        // $matches[0] full, $matches[1] group1
preg_match("/<pattern>/i", $subject, $matches)       // case-insensitive
preg_match_all("/<pattern>/", $subject, $matches)    // all matches

# PHP: regex replace
preg_replace("/<pattern>/", "<replacement>", $str)
preg_replace("/<pattern>/e", "<code>", $str)         // deprecated — use callback
preg_replace_callback("/<pattern>/", function($m) {
    return strtoupper($m[0]);
}, $str)

# PHP: regex split
preg_split("/<pattern>/", $str)
preg_split("/[\s,]+/", "one two,three")  // split on space or comma

# PHP: named groups
preg_match("/(?P<year>\d{4})-(?P<month>\d{2})-(?P<day>\d{2})/", $str, $m);
echo $m["year"], $m["month"], $m["day"];

# PHP: common patterns
$patterns = [
    "email"  => "/^[\w.+-]+@[\w-]+\.[\w.]{2,}$/i",
    "url"    => "/^https?:\/\/.+/i",
    "uuid"   => "/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i",
    "slug"   => "/^[a-z0-9]+(?:-[a-z0-9]+)*$/",
    "ip"     => "/^(\d{1,3}\.){3}\d{1,3}$/",
    "date"   => "/^\d{4}-\d{2}-\d{2}$/",
    "digits" => "/^\d+$/",
];

$ pattern: echo "'\d+' '[a-z]+' '\w+@\w+\.\w+' '\d{4}-\d{2}-\d{2}'"
$ replacement: echo "'$1' '<b>$0</b>' ''"

; ─────────────────────────────────────────────
; DATE & TIME
; ─────────────────────────────────────────────

% php, date, time, datetime, carbon, timestamp

# PHP: current date/time
$now = new \DateTime();
$now = new \DateTimeImmutable();         // immutable (preferred)
$now = \DateTimeImmutable::createFromFormat("Y-m-d", "2024-01-15");

# PHP: format date
$now->format("Y-m-d")                   // "2024-01-15"
$now->format("Y-m-d H:i:s")            // "2024-01-15 10:30:00"
$now->format(\DateTime::RFC3339)        // "2024-01-15T10:30:00+00:00"
$now->format("D, d M Y")               // "Mon, 15 Jan 2024"
date("Y-m-d")                           // procedural style (current time)
date("Y-m-d H:i:s", $timestamp)

# PHP: parse date string
$dt = \DateTimeImmutable::createFromFormat("d/m/Y", "15/01/2024");
$dt = new \DateTimeImmutable("2024-01-15 10:30:00");
$dt = new \DateTimeImmutable("next Monday");
$dt = new \DateTimeImmutable("+3 days");

# PHP: date arithmetic
$future  = $now->modify("+7 days");
$past    = $now->modify("-1 month");
$next    = $now->add(new \DateInterval("P1Y2M3D"));    // +1y2m3d
$prev    = $now->sub(new \DateInterval("PT5H"));       // -5h

# PHP: diff between dates
$diff = $start->diff($end);
$diff->days              // total days
$diff->h                 // hours component
$diff->i                 // minutes component
$diff->invert            // 1 if $end < $start

# PHP: Unix timestamp
$ts    = time();                         // current timestamp
$ts    = $now->getTimestamp();
$dt    = (new \DateTimeImmutable())->setTimestamp($ts);
$today = mktime(0, 0, 0, (int)date("m"), (int)date("d"), (int)date("Y"));

# PHP: timezone
$tz  = new \DateTimeZone("Asia/Jakarta");
$now = new \DateTimeImmutable("now", $tz);
$now = $now->setTimezone(new \DateTimeZone("UTC"));
date_default_timezone_set("Asia/Jakarta");   // global default

# PHP: date comparison
$a < $b     // DateTime objects compare directly
$a == $b    // same point in time
$a->getTimestamp() > $b->getTimestamp()

