; ─────────────────────────────────────────────
; LOGGING & DEBUGGING
; ─────────────────────────────────────────────

% php, log, debug, print, dump, var, error

# PHP: output / debug print
var_dump($val)             // type + value, verbose
print_r($val)              // human-readable (arrays/objects)
print_r($val, true)        // return as string instead of echo
var_export($val)           // valid PHP syntax output
var_export($val, true)     // return as string

# PHP: formatted dump (dev helper)
function dd(mixed ...$vars): never {
    foreach ($vars as $v) {
        echo "<pre>"; var_dump($v); echo "</pre>";
    }
    exit(1);
}

# PHP: error log
error_log("Something went wrong: $message");
error_log(print_r($data, true));
error_log($e->getMessage() . "\n" . $e->getTraceAsString());

# PHP: PSR-3 logger (Monolog example)
$log = new \Monolog\Logger("app");
$log->pushHandler(new \Monolog\Handler\StreamHandler("app.log", \Monolog\Level::Debug));
$log->info("User logged in", ["user_id" => $id]);
$log->error("DB query failed", ["error" => $e->getMessage(), "sql" => $sql]);

# PHP: assertions (dev/test only)
assert($val > 0, "Value must be positive");

