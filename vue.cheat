# vue3 custom directive
app.directive("focus", {
  mounted(el) {
    el.focus()
  }
})

# vue3 debounce composable
import { ref } from "vue"

export function useDebounce(value, delay) {
  const debounced = ref(value)

  setTimeout(() => {
    debounced.value = value
  }, delay)

  return debounced
}

# vue3 local storage composable
import { ref, watch } from "vue"

export function useLocalStorage(key, value) {
  const state = ref(localStorage.getItem(key) || value)

  watch(state, v => {
    localStorage.setItem(key, v)
  })

  return state
}
