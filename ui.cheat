  <!-- Main content (wider) -->
  <main class="min-w-0 flex-1 space-y-6">
    <!-- Primary content goes here -->
  </main>
  <!-- Aside panel (narrower, sticky) -->
  <aside class="hidden w-72 shrink-0 lg:block">
    <div class="sticky top-20 space-y-4">
      <!-- Widgets / filters / info panels go here -->
    </div>
  </aside>
</div>

$ layout_shell_centered: echo 'Centered Auth Layout' | cat
# Layout — Centered (Auth / Forms)
<div class="flex min-h-screen flex-col items-center justify-center bg-zinc-50 px-4">
  <!-- Logo / Brand -->
  <div class="mb-8 flex items-center gap-2">
    <div class="h-7 w-7 rounded bg-zinc-900"></div>
    <span class="text-lg font-bold text-zinc-900">Acme Inc.</span>
  </div>
  <!-- Form card -->
  <div class="w-full max-w-sm rounded-xl border border-zinc-200 bg-white p-8 shadow-sm">
    <h1 class="text-xl font-semibold text-zinc-900">Sign in to your account</h1>
    <p class="mt-1 text-sm text-zinc-500">Enter your email to continue.</p>
    <div class="mt-6 flex flex-col gap-4">
      <div class="flex flex-col gap-1.5">
        <label class="text-sm font-medium text-zinc-900" for="auth-email">Email</label>
        <input id="auth-email" type="email" placeholder="you@example.com" class="flex h-9 w-full rounded-md border border-zinc-200 bg-white px-3 py-1 text-sm shadow-sm placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-900" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label class="text-sm font-medium text-zinc-900" for="auth-pw">Password</label>
        <input id="auth-pw" type="password" placeholder="••••••••" class="flex h-9 w-full rounded-md border border-zinc-200 bg-white px-3 py-1 text-sm shadow-sm placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-900" />
      </div>
      <button class="w-full rounded-md bg-zinc-900 py-2 text-sm font-medium text-white hover:bg-zinc-700 transition-colors">Sign in</button>
    </div>
    <p class="mt-4 text-center text-xs text-zinc-500">Don't have an account? <a href="#" class="font-medium text-zinc-900 hover:underline">Sign up</a></p>
  </div>
</div>

$ layout_shell_settings: echo 'Settings Layout' | cat
# Layout — Settings Page (Vertical Nav + Panel)
<div class="mx-auto flex max-w-4xl gap-8 px-6 py-10">
  <!-- Settings nav -->
  <nav class="hidden w-48 shrink-0 flex-col gap-0.5 md:flex">
    <p class="mb-2 px-3 text-xs font-semibold uppercase tracking-wider text-zinc-400">Settings</p>
    <a href="#" class="rounded-md bg-zinc-100 px-3 py-2 text-sm font-medium text-zinc-900">Profile</a>
    <a href="#" class="rounded-md px-3 py-2 text-sm text-zinc-600 hover:bg-zinc-100 transition-colors">Account</a>
    <a href="#" class="rounded-md px-3 py-2 text-sm text-zinc-600 hover:bg-zinc-100 transition-colors">Notifications</a>
    <a href="#" class="rounded-md px-3 py-2 text-sm text-zinc-600 hover:bg-zinc-100 transition-colors">Security</a>
    <a href="#" class="rounded-md px-3 py-2 text-sm text-zinc-600 hover:bg-zinc-100 transition-colors">Billing</a>
    <div class="my-2 h-px bg-zinc-100"></div>
    <a href="#" class="rounded-md px-3 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">Danger Zone</a>
  </nav>
  <!-- Settings panel -->
  <div class="min-w-0 flex-1 space-y-8">
    <!-- Setting group -->
    <div class="rounded-xl border border-zinc-200 bg-white p-6">
      <h2 class="text-base font-semibold text-zinc-900">Profile</h2>
      <p class="mt-0.5 text-sm text-zinc-500">Update your personal information.</p>
      <div class="mt-5 flex flex-col gap-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium text-zinc-900" for="s-fname">First name</label>
            <input id="s-fname" type="text" placeholder="Jane" class="flex h-9 w-full rounded-md border border-zinc-200 bg-white px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-zinc-900" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium text-zinc-900" for="s-lname">Last name</label>
            <input id="s-lname" type="text" placeholder="Doe" class="flex h-9 w-full rounded-md border border-zinc-200 bg-white px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-zinc-900" />
          </div>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-sm font-medium text-zinc-900" for="s-email">Email</label>
          <input id="s-email" type="email" placeholder="jane@example.com" class="flex h-9 w-full rounded-md border border-zinc-200 bg-white px-3 py-1 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-zinc-900" />
        </div>
      </div>
      <div class="mt-5 flex justify-end">
        <button class="rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white hover:bg-zinc-700 transition-colors">Save changes</button>
      </div>
    </div>
    <!-- Danger zone -->
    <div class="rounded-xl border border-red-200 bg-white p-6">
      <h2 class="text-base font-semibold text-zinc-900">Delete account</h2>
      <p class="mt-0.5 text-sm text-zinc-500">Once deleted, your account cannot be recovered.</p>
      <div class="mt-4">
        <button class="rounded-md border border-red-200 px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50 transition-colors">Delete account</button>
      </div>
    </div>
  </div>
</div>

$ layout_shell_dashboard: echo 'Dashboard Layout Full' | cat
# Layout — Full Dashboard Page (Sidebar + Grid)
<div class="flex h-screen overflow-hidden bg-zinc-50">
  <!-- Sidebar -->
  <aside class="flex w-60 shrink-0 flex-col border-r border-zinc-200 bg-white px-3 py-4">
    <div class="mb-4 flex items-center gap-2 px-2">
      <div class="h-6 w-6 rounded bg-zinc-900"></div>
      <span class="font-semibold text-zinc-900">Acme</span>
    </div>
    <nav class="flex flex-col gap-0.5 flex-1 text-sm">
      <a href="#" class="rounded-md bg-zinc-100 px-3 py-2 font-medium text-zinc-900">Overview</a>
      <a href="#" class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100 transition-colors">Analytics</a>
      <a href="#" class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100 transition-colors">Orders</a>
      <a href="#" class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100 transition-colors">Customers</a>
      <a href="#" class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100 transition-colors">Products</a>
    </nav>
    <div class="border-t border-zinc-100 pt-3">
      <div class="flex items-center gap-2 px-2 py-1">
        <div class="h-7 w-7 rounded-full bg-zinc-900 text-xs text-white flex items-center justify-center font-semibold">JD</div>
        <div>
          <p class="text-xs font-medium text-zinc-900">Jane Doe</p>
          <p class="text-xs text-zinc-500">jane@acme.com</p>
        </div>
      </div>
    </div>
  </aside>
  <!-- Main -->
  <div class="flex flex-1 flex-col overflow-hidden">
    <header class="flex h-14 items-center justify-between border-b border-zinc-200 bg-white px-6">
      <h1 class="text-sm font-semibold text-zinc-900">Overview</h1>
      <button class="rounded-md bg-zinc-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-zinc-700 transition-colors">Download report</button>
    </header>
    <main class="flex-1 overflow-y-auto p-6 space-y-6">
      <!-- Stat cards row -->
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-sm">
          <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Total Revenue</p>
          <p class="mt-2 text-2xl font-bold text-zinc-900">$45,231</p>
          <p class="mt-0.5 text-xs text-emerald-600">+20.1% from last month</p>
        </div>
        <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-sm">
          <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Subscriptions</p>
          <p class="mt-2 text-2xl font-bold text-zinc-900">+2,350</p>
          <p class="mt-0.5 text-xs text-emerald-600">+180.1% from last month</p>
        </div>
        <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-sm">
          <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Sales</p>
          <p class="mt-2 text-2xl font-bold text-zinc-900">+12,234</p>
          <p class="mt-0.5 text-xs text-emerald-600">+19% from last month</p>
        </div>
        <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-sm">
          <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Active Now</p>
          <p class="mt-2 text-2xl font-bold text-zinc-900">+573</p>
          <p class="mt-0.5 text-xs text-zinc-500">+201 since last hour</p>
        </div>
      </div>
      <!-- Content grid: chart placeholder + recent list -->
      <div class="grid gap-4 lg:grid-cols-3">
        <div class="lg:col-span-2 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-sm font-semibold text-zinc-900">Overview</h2>
          <div class="mt-4 h-48 rounded-lg bg-zinc-50 border border-dashed border-zinc-200 flex items-center justify-center text-sm text-zinc-400">Chart placeholder</div>
        </div>
        <div class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-sm font-semibold text-zinc-900">Recent Sales</h2>
          <ul class="mt-4 divide-y divide-zinc-100 text-sm">
            <li class="flex items-center justify-between py-2.5">
              <div class="flex items-center gap-2">
                <div class="h-7 w-7 rounded-full bg-zinc-200 flex items-center justify-center text-xs text-zinc-600">OL</div>
                <div>
                  <p class="font-medium text-zinc-900">Olivia L.</p>
                  <p class="text-xs text-zinc-500">olivia@email.com</p>
                </div>
              </div>
              <span class="font-semibold text-zinc-900">+$250</span>
            </li>
            <li class="flex items-center justify-between py-2.5">
              <div class="flex items-center gap-2">
                <div class="h-7 w-7 rounded-full bg-zinc-200 flex items-center justify-center text-xs text-zinc-600">JL</div>
                <div>
                  <p class="font-medium text-zinc-900">Jackson L.</p>
                  <p class="text-xs text-zinc-500">jackson@email.com</p>
                </div>
              </div>
              <span class="font-semibold text-zinc-900">+$150</span>
            </li>
            <li class="flex items-center justify-between py-2.5">
              <div class="flex items-center gap-2">
                <div class="h-7 w-7 rounded-full bg-zinc-200 flex items-center justify-center text-xs text-zinc-600">IS</div>
                <div>
                  <p class="font-medium text-zinc-900">Isabella S.</p>
                  <p class="text-xs text-zinc-500">isabella@email.com</p>
                </div>
              </div>
              <span class="font-semibold text-zinc-900">+$350</span>
            </li>
          </ul>
        </div>
