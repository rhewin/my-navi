% ui, drawer, sidebar, tailwind, css

# drawer
<input type="checkbox" id="drawer-toggle" class="hidden peer">

<label for="drawer-toggle"
  class="px-3 py-2 bg-blue-500 text-white rounded cursor-pointer">
  Toggle Menu
</label>

<div class="fixed left-0 top-0 h-full w-64 bg-gray-900 text-white
            -translate-x-full peer-checked:translate-x-0 transition-transform">
  <div class="p-4">Sidebar</div>
</div>

