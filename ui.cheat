% ui, dropdown, tailwind, css

# dropdown
<div tabindex="0" class="relative group">
  <button class="px-3 py-2 bg-gray-200 rounded">Menu</button>

  <div class="absolute mt-2 bg-white border rounded shadow hidden
              group-focus-within:block">
    <div class="px-3 py-2 hover:bg-gray-100">Item</div>
  </div>
</div>

