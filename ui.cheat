    <div class="mt-10 border-t border-zinc-100 pt-6 flex flex-col items-center justify-between gap-2 text-xs text-zinc-400 sm:flex-row">
      <p>© 2026 Acme Inc. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="#" class="hover:text-zinc-700 transition-colors">Twitter</a>
        <a href="#" class="hover:text-zinc-700 transition-colors">GitHub</a>
        <a href="#" class="hover:text-zinc-700 transition-colors">LinkedIn</a>
