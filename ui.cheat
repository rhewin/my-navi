% ui, modal, tailwind, css

# modal (no js)
<input type="checkbox" id="modal" class="hidden peer">

<label for="modal" class="px-3 py-2 bg-blue-500 text-white rounded cursor-pointer">
  Open
</label>

<div class="fixed inset-0 bg-black/50 hidden peer-checked:flex items-center justify-center">
  <div class="bg-white p-6 rounded shadow">
    Modal
    <label for="modal" class="block mt-4 border px-2 py-1 cursor-pointer">Close</label>
  </div>
</div>

---

% ui, toast, tailwind, js

# toast auto-dismiss
<div id="toast" class="fixed bottom-4 right-4 bg-black text-white px-4 py-2 rounded hidden">
  Saved!
</div>

<script>
function showToast(){
  const t = document.getElementById("toast");
  t.classList.remove("hidden");
  setTimeout(()=>t.classList.add("hidden"),2000);
}
</script>

