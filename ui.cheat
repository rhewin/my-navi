% ui, modal, tailwind, css

# modal (no js)
<input type="checkbox" id="modal-toggle" class="hidden peer">

<label for="modal-toggle"
  class="px-4 py-2 bg-blue-500 text-white rounded cursor-pointer">
  Open Modal
</label>

<div class="fixed inset-0 bg-black/50 hidden peer-checked:flex items-center justify-center">
  <div class="bg-white p-6 rounded shadow w-full max-w-md">
    <h2 class="font-bold mb-2">Modal Title</h2>
    <p class="mb-4">Modal content</p>

    <label for="modal-toggle"
      class="px-3 py-1 border rounded cursor-pointer">
      Close
    </label>
  </div>
</div>

---

% ui, dropdown, tailwind, css

# dropdown (focus)
<div tabindex="0" class="relative inline-block group">
  <button class="px-4 py-2 bg-gray-200 rounded">
    Menu
  </button>

  <div class="absolute right-0 mt-2 w-40 bg-white border rounded shadow
              hidden group-focus-within:block">
    <div class="px-4 py-2 hover:bg-gray-100">Profile</div>
    <div class="px-4 py-2 hover:bg-gray-100">Logout</div>
  </div>
</div>

---

% ui, tabs, tailwind, css

# tabs (radio)
<input type="radio" name="tab-group" id="tab-one" class="hidden peer/tab1" checked>
<input type="radio" name="tab-group" id="tab-two" class="hidden peer/tab2">

<div class="flex gap-4 border-b mb-4">
  <label for="tab-one" class="cursor-pointer pb-2">Tab 1</label>
  <label for="tab-two" class="cursor-pointer pb-2">Tab 2</label>
</div>

<div>
  <div class="hidden peer-checked/tab1:block">Content 1</div>
  <div class="hidden peer-checked/tab2:block">Content 2</div>
</div>

---

% ui, accordion, tailwind, css

# accordion
<input type="checkbox" id="accordion-toggle" class="hidden peer">

<label for="accordion-toggle"
  class="block px-4 py-2 bg-gray-100 cursor-pointer">
  Accordion Title
</label>

<div class="max-h-0 overflow-hidden peer-checked:max-h-40 transition-all px-4">
  Accordion content
</div>

