$ layout_section_faq: echo 'FAQ Section' | cat
# Section — FAQ Accordion
<section class="px-6 py-20">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-center text-3xl font-bold text-zinc-900">Frequently asked questions</h2>
    <div class="mt-10 divide-y divide-zinc-200 rounded-xl border border-zinc-200">
      <details class="group p-5">
        <summary class="flex cursor-pointer items-center justify-between text-sm font-medium text-zinc-900 list-none">
          What is your refund policy?
          <svg class="h-4 w-4 text-zinc-400 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <p class="mt-3 text-sm text-zinc-500">We offer a full refund within 30 days of purchase, no questions asked.</p>
      </details>
      <details class="group p-5">
        <summary class="flex cursor-pointer items-center justify-between text-sm font-medium text-zinc-900 list-none">
          Can I change my plan later?
          <svg class="h-4 w-4 text-zinc-400 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <p class="mt-3 text-sm text-zinc-500">Yes, you can upgrade or downgrade at any time from your account settings.</p>
      </details>
      <details class="group p-5">
        <summary class="flex cursor-pointer items-center justify-between text-sm font-medium text-zinc-900 list-none">
          Do you support SSO?
          <svg class="h-4 w-4 text-zinc-400 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <p class="mt-3 text-sm text-zinc-500">SSO with SAML 2.0 is available on the Enterprise plan.</p>
      </details>
    </div>
  </div>
</section>
