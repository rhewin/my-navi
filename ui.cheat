% ui, tabs, tailwind, css

# tabs
<input type="radio" name="tab" id="t1" class="hidden peer/t1" checked>
<input type="radio" name="tab" id="t2" class="hidden peer/t2">

<label for="t1">Tab1</label>
<label for="t2">Tab2</label>

<div>
  <div class="peer-checked/t1:block hidden">Content1</div>
  <div class="peer-checked/t2:block hidden">Content2</div>
</div>

