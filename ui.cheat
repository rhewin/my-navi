</div>

$ layout_shell_marketing: echo 'Marketing Landing Page' | cat
# Layout — Marketing / Landing Page (full structure)
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Product Landing</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-zinc-900 antialiased">
  <!-- Navbar -->
  <nav class="sticky top-0 z-40 flex h-14 items-center border-b border-zinc-100 bg-white/90 backdrop-blur-md px-6">
    <a href="#" class="flex items-center gap-2 font-semibold"><div class="h-5 w-5 rounded bg-zinc-900"></div>Acme</a>
    <div class="ml-auto flex items-center gap-4">
      <a href="#features" class="hidden text-sm text-zinc-500 hover:text-zinc-900 transition-colors md:block">Features</a>
      <a href="#pricing" class="hidden text-sm text-zinc-500 hover:text-zinc-900 transition-colors md:block">Pricing</a>
      <button class="rounded-md bg-zinc-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-zinc-700 transition-colors">Get started</button>
    </div>
  </nav>
  <!-- Hero -->
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-2xl">
      <span class="inline-flex items-center rounded-full border border-zinc-200 bg-zinc-50 px-3 py-1 text-xs font-medium text-zinc-600 mb-4">✦ New — Version 2.0 is here</span>
      <h1 class="text-5xl font-bold tracking-tight">Build better products, faster</h1>
      <p class="mt-5 text-lg text-zinc-500">The all-in-one platform that helps teams ship with confidence. From idea to production in minutes.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <button class="rounded-md bg-zinc-900 px-6 py-2.5 text-sm font-medium text-white hover:bg-zinc-700 transition-colors">Start for free</button>
        <button class="rounded-md border border-zinc-200 bg-white px-6 py-2.5 text-sm font-medium text-zinc-900 hover:bg-zinc-50 transition-colors">View demo →</button>
      </div>
    </div>
  </section>
  <!-- Feature section -->
  <section id="features" class="border-t border-zinc-100 bg-zinc-50 px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold">Everything you need</h2>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <div class="h-9 w-9 rounded-lg bg-zinc-900 flex items-center justify-center mb-4"><svg class="h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
          <h3 class="font-semibold">Blazing fast</h3>
          <p class="mt-1 text-sm text-zinc-500">Optimized for performance from day one.</p>
        </div>
        <div class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <div class="h-9 w-9 rounded-lg bg-zinc-900 flex items-center justify-center mb-4"><svg class="h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
          <h3 class="font-semibold">Secure by default</h3>
          <p class="mt-1 text-sm text-zinc-500">Enterprise-grade security out of the box.</p>
        </div>
        <div class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <div class="h-9 w-9 rounded-lg bg-zinc-900 flex items-center justify-center mb-4"><svg class="h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <h3 class="font-semibold">Team-ready</h3>
          <p class="mt-1 text-sm text-zinc-500">Built for collaboration at any scale.</p>
        </div>
      </div>
    </div>
  </section>
  <!-- Footer -->
  <footer class="border-t border-zinc-100 px-6 py-8">
    <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 text-sm text-zinc-400 sm:flex-row">
      <div class="flex items-center gap-2"><div class="h-4 w-4 rounded bg-zinc-900"></div>Acme Inc.</div>
      <div class="flex gap-6">
        <a href="#" class="hover:text-zinc-700 transition-colors">Privacy</a>
        <a href="#" class="hover:text-zinc-700 transition-colors">Terms</a>
        <a href="#" class="hover:text-zinc-700 transition-colors">Contact</a>
      </div>
    </div>
  </footer>
</body>
</html>

$ layout_footer: echo 'Footer' | cat
