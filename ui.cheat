% ui, table, tailwind

# data table (static)
<div class="bg-white p-4 rounded shadow">
  <table class="w-full text-left">
    <thead class="bg-gray-100">
      <tr>
        <th class="p-2">Name</th>
        <th class="p-2">Status</th>
      </tr>
    </thead>
    <tbody>
      <tr class="border-t hover:bg-gray-50">
        <td class="p-2">John Doe</td>
        <td class="p-2">
          <span class="px-2 py-1 text-xs bg-green-100 text-green-700 rounded">
            Active
          </span>
        </td>
      </tr>
    </tbody>
  </table>
</div>

---

% ui, table, sort, js

# table (sortable)
<table class="w-full border" id="user-table">
  <thead class="bg-gray-100">
    <tr>
      <th class="p-2 cursor-pointer" onclick="sortUserTable()">Name ↑↓</th>
    </tr>
  </thead>
  <tbody>
    <tr><td class="p-2">John</td></tr>
    <tr><td class="p-2">Alice</td></tr>
  </tbody>
</table>

<script>
function sortUserTable() {
  const tbody = document.querySelector("#user-table tbody");
  const rows = Array.from(tbody.rows);
  rows.sort((a, b) => a.innerText.localeCompare(b.innerText));
  rows.forEach(row => tbody.appendChild(row));
}
</script>

---

% ui, chart, tailwind, js

# bar chart
<div id="bar-chart" class="flex items-end gap-2 h-40"></div>

<script>
const chartData = [12, 30, 18, 45];
const chartEl = document.getElementById("bar-chart");

chartEl.innerHTML = chartData.map(value =>
  `<div class="bg-blue-500 w-6" style="height:${value * 2}px"></div>`
).join("");
</script>

---

% ui, calendar, js

# calendar (interactive)
<div class="w-72 bg-white p-4 rounded shadow">
  <div class="flex justify-between mb-2">
    <button onclick="prevMonth()">←</button>
    <span id="calendar-month"></span>
    <button onclick="nextMonth()">→</button>
  </div>
  <div id="calendar-grid" class="grid grid-cols-7 gap-1 text-center text-sm"></div>
</div>

<script>
let calendarDate = new Date();

function renderCalendar() {
  const grid = document.getElementById("calendar-grid");
  const label = document.getElementById("calendar-month");
  grid.innerHTML = "";

  const year = calendarDate.getFullYear();
  const month = calendarDate.getMonth();

  label.textContent = calendarDate.toLocaleString("default", {
    month: "long",
    year: "numeric"
  });

  const firstDay = new Date(year, month, 1).getDay();
  const totalDays = new Date(year, month + 1, 0).getDate();

  for (let i = 0; i < firstDay; i++) {
    grid.innerHTML += "<div></div>";
  }

  for (let day = 1; day <= totalDays; day++) {
    grid.innerHTML += `<div class="p-1 rounded hover:bg-blue-100 cursor-pointer">${day}</div>`;
  }
}

function prevMonth() {
  calendarDate.setMonth(calendarDate.getMonth() - 1);
  renderCalendar();
}

function nextMonth() {
  calendarDate.setMonth(calendarDate.getMonth() + 1);
  renderCalendar();
}

renderCalendar();
</script>

---

% ui, combobox, js

# combobox (filter)
<div class="w-64">
  <input id="combo-input" class="w-full border px-3 py-2 rounded" placeholder="Search fruit">
  <div id="combo-list" class="border rounded mt-1"></div>
</div>

<script>
const comboItems = ["Apple", "Banana", "Orange"];
const comboList = document.getElementById("combo-list");

document.getElementById("combo-input").oninput = function (e) {
  const value = e.target.value.toLowerCase();
  comboList.innerHTML = comboItems
    .filter(item => item.toLowerCase().includes(value))
    .map(item => `<div class="px-3 py-2 hover:bg-gray-100">${item}</div>`)
    .join("");
};
</script>

