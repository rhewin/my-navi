$ layout_pricing: echo 'Pricing Section' | cat
# Section — Pricing Cards (3-tier)
<section class="px-6 py-20 bg-white">
  <div class="mx-auto max-w-5xl">
    <h2 class="text-center text-3xl font-bold text-zinc-900">Simple, transparent pricing</h2>
    <p class="mt-2 text-center text-sm text-zinc-500">No hidden fees. Cancel anytime.</p>
    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      <!-- Free tier -->
      <div class="rounded-xl border border-zinc-200 p-6 flex flex-col">
        <p class="text-sm font-medium text-zinc-500">Free</p>
        <p class="mt-2 text-4xl font-bold text-zinc-900">$0<span class="text-base font-medium text-zinc-400">/mo</span></p>
        <p class="mt-2 text-sm text-zinc-500">For individuals getting started.</p>
        <ul class="mt-6 space-y-2 flex-1">
          <li class="flex items-center gap-2 text-sm text-zinc-700"><svg class="h-4 w-4 text-emerald-500 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>3 projects</li>
          <li class="flex items-center gap-2 text-sm text-zinc-700"><svg class="h-4 w-4 text-emerald-500 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Community support</li>
        </ul>
        <button class="mt-6 w-full rounded-md border border-zinc-200 bg-white py-2 text-sm font-medium text-zinc-900 hover:bg-zinc-50 transition-colors">Get started</button>
      </div>
      <!-- Pro tier (highlighted) -->
      <div class="rounded-xl border-2 border-zinc-900 bg-zinc-900 p-6 flex flex-col relative">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-zinc-900 border border-zinc-700 px-3 py-0.5 text-xs font-semibold text-white">Most popular</span>
        <p class="text-sm font-medium text-zinc-400">Pro</p>
        <p class="mt-2 text-4xl font-bold text-white">$19<span class="text-base font-medium text-zinc-400">/mo</span></p>
        <p class="mt-2 text-sm text-zinc-400">For growing teams and professionals.</p>
        <ul class="mt-6 space-y-2 flex-1">
          <li class="flex items-center gap-2 text-sm text-zinc-300"><svg class="h-4 w-4 text-emerald-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Unlimited projects</li>
          <li class="flex items-center gap-2 text-sm text-zinc-300"><svg class="h-4 w-4 text-emerald-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Priority support</li>
          <li class="flex items-center gap-2 text-sm text-zinc-300"><svg class="h-4 w-4 text-emerald-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Analytics dashboard</li>
        </ul>
        <button class="mt-6 w-full rounded-md bg-white py-2 text-sm font-medium text-zinc-900 hover:bg-zinc-100 transition-colors">Get started</button>
      </div>
      <!-- Enterprise tier -->
      <div class="rounded-xl border border-zinc-200 p-6 flex flex-col">
        <p class="text-sm font-medium text-zinc-500">Enterprise</p>
        <p class="mt-2 text-4xl font-bold text-zinc-900">Custom</p>
        <p class="mt-2 text-sm text-zinc-500">For large organizations with custom needs.</p>
        <ul class="mt-6 space-y-2 flex-1">
          <li class="flex items-center gap-2 text-sm text-zinc-700"><svg class="h-4 w-4 text-emerald-500 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>SSO & SAML</li>
          <li class="flex items-center gap-2 text-sm text-zinc-700"><svg class="h-4 w-4 text-emerald-500 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Dedicated SLA</li>
          <li class="flex items-center gap-2 text-sm text-zinc-700"><svg class="h-4 w-4 text-emerald-500 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Audit logs</li>
        </ul>
        <button class="mt-6 w-full rounded-md border border-zinc-200 bg-white py-2 text-sm font-medium text-zinc-900 hover:bg-zinc-50 transition-colors">Contact sales</button>
      </div>
    </div>
  </div>
</section>

