; ─────────────────────────────────────────────
; DEFER, PANIC, RECOVER
; ─────────────────────────────────────────────

% golang, go, defer, panic, recover, cleanup

# Go: defer - LIFO execution on function return
defer f.Close()
defer wg.Done()
defer cancel()
defer func() {
    // cleanup code
}()

# Go: defer with loop (watch out - defer runs at end of FUNCTION not loop)
for _, f := range files {
    f := f  // capture
    defer f.Close()  // BAD: all deferred at function end
}
// CORRECT: use anonymous function per iteration
for _, f := range files {
    func() {
        defer f.Close()
        process(f)
    }()
}

# Go: panic and recover
func safeExecute(fn func()) (err error) {
    defer func() {
        if r := recover(); r != nil {
            err = fmt.Errorf("panic: %v\n%s", r, debug.Stack())
        }
    }()
    fn()
    return nil
}

// Panic with value:
panic("something went terribly wrong")
panic(fmt.Errorf("critical: %w", err))

; ─────────────────────────────────────────────
; ENCODING / DECODING
; ─────────────────────────────────────────────

% golang, go, encoding, json, base64, csv, xml

# Go: base64 encode / decode
encoded := base64.StdEncoding.EncodeToString([]byte("hello"))
decoded, err := base64.StdEncoding.DecodeString(encoded)

// URL-safe (no padding)
encoded := base64.URLEncoding.EncodeToString(data)
encoded := base64.RawURLEncoding.EncodeToString(data)  // no padding

# Go: json - stream encode/decode (large payloads)
enc := json.NewEncoder(w)
enc.SetIndent("", "  ")
enc.Encode(v)

dec := json.NewDecoder(r.Body)
dec.DisallowUnknownFields()  // strict mode
err := dec.Decode(&v)

# Go: json - custom marshal/unmarshal
type MyTime time.Time

func (t MyTime) MarshalJSON() ([]byte, error) {
    return json.Marshal(time.Time(t).Format(time.RFC3339))
}

func (t *MyTime) UnmarshalJSON(data []byte) error {
    var s string
    if err := json.Unmarshal(data, &s); err != nil {
        return err
    }
    parsed, err := time.Parse(time.RFC3339, s)
    *t = MyTime(parsed)
    return err
}

# Go: CSV read
f, _ := os.Open("data.csv")
defer f.Close()
r := csv.NewReader(f)
r.TrimLeadingSpace = true
records, err := r.ReadAll()
// or row by row:
for {
    record, err := r.Read()
    if err == io.EOF { break }
}

# Go: CSV write
w := csv.NewWriter(os.Stdout)
defer w.Flush()
w.Write([]string{"name", "age", "email"})
w.WriteAll(records)

# Go: XML
type Person struct {
    XMLName xml.Name `xml:"person"`
    Name    string   `xml:"name"`
    Age     int      `xml:"age,attr"`
}

data, err := xml.Marshal(&p)
data, err := xml.MarshalIndent(&p, "", "  ")
err = xml.Unmarshal(data, &p)

; ─────────────────────────────────────────────
; MODULES & PACKAGES
; ─────────────────────────────────────────────

% golang, go, module, package, mod, dep, dependency

# Go: module commands
// go mod init <module-path>
// go mod tidy                   add missing / remove unused deps
// go mod download               download deps to cache
// go mod verify                 verify checksums
// go mod vendor                 copy deps to ./vendor
// go list -m all                list all deps
// go get <pkg>@<version>        add or update dep
// go get <pkg>@latest           get latest version
// go get <pkg>@none             remove dep

# Go: build and run
// go build ./...                build all packages
// go run .                      run main package
// go run ./cmd/server           run specific command
// go vet ./...                  static analysis
// go clean -testcache           clear test cache

# Go: workspace (Go 1.18+)
// go work init ./module1 ./module2
// go work use ./module3

# Go: cross-compilation
// GOOS=linux GOARCH=amd64 go build -o bin/server .
// GOOS=windows GOARCH=amd64 go build -o bin/server.exe .
// GOOS=darwin GOARCH=arm64 go build -o bin/server-mac .

# Go: build tags
//go:build linux && amd64
// (first line of file, before package declaration)

// go build -tags integration ./...

# Go: ldflags (embed version at build time)
// go build -ldflags="-X main.version=1.2.3 -X main.commit=$(git rev-parse HEAD)"
var (
    version = "dev"
    commit  = "none"
)
