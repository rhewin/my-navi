% golang, go, basics, common

; ─────────────────────────────────────────────
; FOR RANGE LOOPS
; ─────────────────────────────────────────────

# Go: for range over slice
for i, v := range <slice> {
    fmt.Printf("index=%d value=%v\n", i, v)
}

# Go: for range over map
for k, v := range <map> {
    fmt.Printf("key=%s value=%v\n", k, v)
}

# Go: for range over string (runes)
for i, r := range "<string>" {
    fmt.Printf("index=%d rune=%c\n", i, r)
}

# Go: for range over channel
for v := range <channel> {
    fmt.Println(v)
}

# Go: range with blank identifier (index only)
for i := range <slice> {
    fmt.Println(i)
}

# Go: classic C-style for loop
for i := 0; i < <n>; i++ {
    fmt.Println(i)
}

# Go: infinite loop with break
for {
    if <condition> {
        break
    }
}

