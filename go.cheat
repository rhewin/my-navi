; ─────────────────────────────────────────────
; STRUCTS
; ─────────────────────────────────────────────

% golang, go, struct

# Go: struct definition with tags
type <Name> struct {
    ID        int       `json:"id"         db:"id"`
    Name      string    `json:"name"       db:"name"        validate:"required"`
    Email     string    `json:"email"      db:"email"       validate:"required,email"`
    CreatedAt time.Time `json:"created_at" db:"created_at"`
    deleted   bool      // unexported field
}

# Go: struct embedding (composition over inheritance)
type Base struct {
    ID        int
    CreatedAt time.Time
    UpdatedAt time.Time
}

type User struct {
    Base              // embed - promotes fields & methods
    Name  string
    Email string
}

u := User{Name: "Alice"}
fmt.Println(u.ID)        // promoted from Base
fmt.Println(u.CreatedAt) // promoted from Base

# Go: struct methods - value vs pointer receiver
// Value receiver: does NOT modify original
func (u User) FullName() string {
    return u.FirstName + " " + u.LastName
}

// Pointer receiver: CAN modify original, preferred for mutation
func (u *User) Deactivate() {
    u.Active = false
}

# Go: constructor pattern
func New<Name>(name, email string) (*<Name>, error) {
    if name == "" {
        return nil, errors.New("name is required")
    }
    return &<Name>{
        Name:      name,
        Email:     email,
        CreatedAt: time.Now(),
    }, nil
}

# Go: struct with interface implementation
type Stringer interface {
    String() string
}

func (u User) String() string {
    return fmt.Sprintf("User{ID:%d Name:%s}", u.ID, u.Name)
}

# Go: struct comparison and zero value check
var u User                      // zero value
fmt.Println(u == (User{}))     // true if all fields comparable
fmt.Println(reflect.DeepEqual(u, User{})) // works for all types

