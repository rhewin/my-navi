; ─────────────────────────────────────────────
; WORKER POOL
; ─────────────────────────────────────────────

% golang, go, worker, pool, concurrency

# Go: worker pool pattern
func workerPool(numWorkers int, jobs <-chan Job, results chan<- Result) {
    var wg sync.WaitGroup
    for i := 0; i < numWorkers; i++ {
        wg.Add(1)
        go func(id int) {
            defer wg.Done()
            for job := range jobs {  // exits when jobs channel is closed
                result := process(job)
                results <- result
            }
        }(i)
    }
    wg.Wait()
    close(results)
}

// Producer:
func produce(jobs chan<- Job, data []Job) {
    defer close(jobs)  // signal workers: no more work
    for _, job := range data {
        jobs <- job
    }
}

// Usage:
jobs    := make(chan Job, 100)
results := make(chan Result, 100)

go produce(jobs, myData)
go workerPool(<numWorkers>, jobs, results)

for r := range results {
    fmt.Println(r)
}

# Go: worker pool with context cancellation
func workerPoolCtx(ctx context.Context, n int, jobs <-chan Job, results chan<- Result) {
    var wg sync.WaitGroup
    for i := 0; i < n; i++ {
        wg.Add(1)
        go func() {
            defer wg.Done()
            for {
                select {
                case job, ok := <-jobs:
                    if !ok {
                        return
                    }
                    results <- process(job)
                case <-ctx.Done():
                    return
                }
            }
        }()
    }
    go func() {
        wg.Wait()
        close(results)
    }()
}

# Go: fan-out / fan-in
func fanOut(in <-chan Work, n int) []<-chan Result {
    outs := make([]<-chan Result, n)
    for i := 0; i < n; i++ {
        outs[i] = worker(in)
    }
    return outs
}

func fanIn(cs ...<-chan Result) <-chan Result {
    merged := make(chan Result)
    var wg sync.WaitGroup
    for _, c := range cs {
        wg.Add(1)
        go func(ch <-chan Result) {
            defer wg.Done()
            for v := range ch {
                merged <- v
            }
        }(c)
    }
    go func() { wg.Wait(); close(merged) }()
    return merged
}

$ numWorkers: echo "4 8 16 runtime.NumCPU()"

; ─────────────────────────────────────────────
; RATE LIMITER
; ─────────────────────────────────────────────

% golang, go, rate, limiter, throttle

# Go: rate limiter - token bucket (golang.org/x/time/rate)
import "golang.org/x/time/rate"

limiter := rate.NewLimiter(rate.Limit(<rps>), <burst>)

// Block until a token is available
if err := limiter.Wait(ctx); err != nil {
    return err
}

// Non-blocking: attempt to take a token
if !limiter.Allow() {
    return errors.New("rate limit exceeded")
}

// Reserve a token (inspect delay before executing)
r := limiter.Reserve()
if !r.OK() {
    return errors.New("exceeds max burst")
}
time.Sleep(r.Delay())

# Go: rate limiter - per-key (e.g. per user/IP)
type PerKeyLimiter struct {
    mu       sync.Mutex
    limiters map[string]*rate.Limiter
    rps      rate.Limit
    burst    int
}

func (pkl *PerKeyLimiter) Get(key string) *rate.Limiter {
    pkl.mu.Lock()
    defer pkl.mu.Unlock()
    if l, ok := pkl.limiters[key]; ok {
        return l
    }
    l := rate.NewLimiter(pkl.rps, pkl.burst)
    pkl.limiters[key] = l
    return l
}

// Usage in HTTP middleware:
func (pkl *PerKeyLimiter) Middleware(next http.Handler) http.Handler {
    return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        key := r.RemoteAddr // or user ID from JWT
        if !pkl.Get(key).Allow() {
            http.Error(w, "Too Many Requests", http.StatusTooManyRequests)
            return
        }
        next.ServeHTTP(w, r)
    })
}

# Go: rate limiter - simple ticker-based
ticker := time.NewTicker(time.Second / time.Duration(<rps>))
defer ticker.Stop()

for job := range jobs {
    <-ticker.C  // wait for tick = respect rate limit
    go process(job)
}

# Go: rate limiter - semaphore (limit concurrency)
sem := make(chan struct{}, <maxConcurrent>)

for _, item := range items {
    sem <- struct{}{}  // acquire
    go func(item Item) {
        defer func() { <-sem }()  // release
        process(item)
    }(item)
}
// drain semaphore to wait for all goroutines
for i := 0; i < cap(sem); i++ {
    sem <- struct{}{}
}

