% golang, go, basics, common

; ─────────────────────────────────────────────
; FOR RANGE LOOPS
; ─────────────────────────────────────────────

# Go: for range over slice
for i, v := range <slice> {
    fmt.Printf("index=%d value=%v\n", i, v)
}

# Go: for range over map
for k, v := range <map> {
    fmt.Printf("key=%s value=%v\n", k, v)
}

# Go: for range over string (runes)
for i, r := range "<string>" {
    fmt.Printf("index=%d rune=%c\n", i, r)
}

# Go: for range over channel
for v := range <channel> {
    fmt.Println(v)
}

# Go: range with blank identifier (index only)
for i := range <slice> {
    fmt.Println(i)
}

# Go: classic C-style for loop
for i := 0; i < <n>; i++ {
    fmt.Println(i)
}

# Go: while-style loop
for <condition> {
    // loop body
}

# Go: infinite loop with break
for {
    if <condition> {
        break
    }
}

$ slice: echo "mySlice nums words items"
$ map: echo "myMap config env headers"
$ channel: echo "ch jobs results"
$ string: echo "hello, 世界"
$ n: echo "10 100 1000"
$ condition: echo "done err != nil ctx.Done()"

; ─────────────────────────────────────────────
; SWITCH STATEMENTS
; ─────────────────────────────────────────────

% golang, go, switch, control-flow

# Go: switch on value
switch <variable> {
case "<val1>":
    fmt.Println("matched val1")
case "<val2>", "<val3>":
    fmt.Println("matched val2 or val3")
default:
    fmt.Println("no match")
}

# Go: switch with no condition (like if-else chain)
switch {
case x < 0:
    fmt.Println("negative")
case x == 0:
    fmt.Println("zero")
default:
    fmt.Println("positive")
}

# Go: switch on type (type switch)
switch v := <iface>.(type) {
case int:
    fmt.Printf("int: %d\n", v)
case string:
    fmt.Printf("string: %s\n", v)
case error:
    fmt.Printf("error: %v\n", v)
default:
    fmt.Printf("unknown: %T\n", v)
}

# Go: switch with fallthrough
switch <variable> {
case 1:
    fmt.Println("one")
    fallthrough
case 2:
    fmt.Println("two or fell through from one")
default:
    fmt.Println("other")
}

$ variable: echo "status code errType val"
$ iface: echo "i val obj result"
$ val1: echo "active pending done error"
$ val2: echo "running stopped"
$ val3: echo "paused idle"

; ─────────────────────────────────────────────
; VARIABLES & DECLARATIONS
; ─────────────────────────────────────────────

% golang, go, variables, declaration, basics

# Go: variable declaration forms
var x int          // zero value
var x int = 10     // explicit type + value
x := 10            // short declaration (infers type)
var x, y int = 1, 2
x, y := 1, 2

# Go: const declaration
const Pi = 3.14159
const (
    StatusOK    = 200
    StatusNotFound = 404
)

# Go: iota - auto-incrementing const
type Direction int
const (
    North Direction = iota // 0
    East                   // 1
    South                  // 2
    West                   // 3
)

# Go: iota with bit shift (flags/bitmask)
type Permission uint
const (
    Read    Permission = 1 << iota // 1
    Write                          // 2
    Execute                        // 4
)

# Go: multiple return values
func minMax(nums []int) (min, max int) {
    min, max = nums[0], nums[0]
    for _, v := range nums[1:] {
        if v < min { min = v }
        if v > max { max = v }
    }
    return // naked return
}

# Go: blank identifier
_, err := someFunc()   // discard first return value
for _, v := range s {} // discard index

; ─────────────────────────────────────────────
; TYPE CONVERSION
; ─────────────────────────────────────────────

% golang, go, conversion, cast, type, strconv

# Go: numeric type conversion
i := 42
f := float64(i)       // int → float64
u := uint(i)          // int → uint
b := byte(i)          // int → byte (uint8)
r := rune(i)          // int → rune (int32)
i2 := int(f)          // float64 → int (truncates)

# Go: int ↔ string (strconv)
s := strconv.Itoa(42)                         // int → string "42"
n, err := strconv.Atoi("42")                  // string → int
n64, err := strconv.ParseInt("42", 10, 64)    // string → int64 (base, bitSize)
s = strconv.FormatInt(int64(n), 10)           // int64 → string (base 10)
u64, err := strconv.ParseUint("42", 10, 64)   // string → uint64

# Go: float ↔ string (strconv)
s := strconv.FormatFloat(3.14, 'f', 2, 64)   // float64 → "3.14" (fmt, prec, bitSize)
f, err := strconv.ParseFloat("3.14", 64)      // string → float64

# Go: bool ↔ string (strconv)
s := strconv.FormatBool(true)           // → "true"
b, err := strconv.ParseBool("true")    // → true (accepts 1, t, T, TRUE, true, etc.)

# Go: string ↔ []byte ↔ []rune
b := []byte("hello")       // string → []byte
s := string(b)             // []byte → string
r := []rune("hello, 世界") // string → []rune (unicode-safe)
s2 := string(r)            // []rune → string

# Go: fmt.Sprintf conversion (any → string)
s := fmt.Sprintf("%d", 42)          // int → string
s := fmt.Sprintf("%.2f", 3.14159)  // float → "3.14"
s := fmt.Sprintf("%v", anyValue)    // any → default format
s := fmt.Sprintf("%T", anyValue)    // any → type name string
s := fmt.Sprintf("%b", 42)         // int → binary string "101010"
s := fmt.Sprintf("%x", 255)        // int → hex "ff"
s := fmt.Sprintf("%08b", 42)       // zero-padded binary

# Go: interface{} / any type assertion
var i any = "hello"
s, ok := i.(string)    // safe assertion; ok=false if wrong type
s := i.(string)        // panics if wrong type — use only when sure

# Go: string number bases
n, err := strconv.ParseInt("0xFF", 0, 64)    // auto-detect base (0x hex, 0 octal, 0b binary)
n, err := strconv.ParseInt("ff", 16, 64)     // explicit hex
n, err := strconv.ParseInt("101010", 2, 64)  // explicit binary
s := fmt.Sprintf("0x%X", n)                  // → "0xFF"

