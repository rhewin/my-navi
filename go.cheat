; ─────────────────────────────────────────────
; SWITCH STATEMENTS
; ─────────────────────────────────────────────

% golang, go, switch

# Go: switch on value
switch <variable> {
case "<val1>":
    fmt.Println("matched val1")
case "<val2>", "<val3>":
    fmt.Println("matched val2 or val3")
default:
    fmt.Println("no match")
}

# Go: switch with no condition (like if-else chain)
switch {
case x < 0:
    fmt.Println("negative")
case x == 0:
    fmt.Println("zero")
default:
    fmt.Println("positive")
}

# Go: switch on type (type switch)
switch v := <iface>.(type) {
case int:
    fmt.Printf("int: %d\n", v)
case string:
    fmt.Printf("string: %s\n", v)
case error:
    fmt.Printf("error: %v\n", v)
default:
    fmt.Printf("unknown: %T\n", v)
}

# Go: switch with fallthrough
switch <variable> {
case 1:
    fmt.Println("one")
    fallthrough
case 2:
    fmt.Println("two or fell through from one")
default:
    fmt.Println("other")
}

