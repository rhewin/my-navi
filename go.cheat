; ─────────────────────────────────────────────
; RATE LIMITER
; ─────────────────────────────────────────────

% golang, go, rate, limiter, throttle, concurrency

# Go: rate limiter - token bucket (golang.org/x/time/rate)
import "golang.org/x/time/rate"

limiter := rate.NewLimiter(rate.Limit(<rps>), <burst>)

// Block until a token is available
if err := limiter.Wait(ctx); err != nil {
    return err
}

// Non-blocking: attempt to take a token
if !limiter.Allow() {
    return errors.New("rate limit exceeded")
}

// Reserve a token (inspect delay before executing)
r := limiter.Reserve()
if !r.OK() {
    return errors.New("exceeds max burst")
}
time.Sleep(r.Delay())

# Go: rate limiter - per-key (e.g. per user/IP)
type PerKeyLimiter struct {
    mu       sync.Mutex
    limiters map[string]*rate.Limiter
    rps      rate.Limit
    burst    int
}

func (pkl *PerKeyLimiter) Get(key string) *rate.Limiter {
    pkl.mu.Lock()
    defer pkl.mu.Unlock()
    if l, ok := pkl.limiters[key]; ok {
        return l
    }
    l := rate.NewLimiter(pkl.rps, pkl.burst)
    pkl.limiters[key] = l
    return l
}

// Usage in HTTP middleware:
func (pkl *PerKeyLimiter) Middleware(next http.Handler) http.Handler {
    return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        key := r.RemoteAddr // or user ID from JWT
        if !pkl.Get(key).Allow() {
            http.Error(w, "Too Many Requests", http.StatusTooManyRequests)
            return
        }
        next.ServeHTTP(w, r)
    })
}

# Go: rate limiter - simple ticker-based
ticker := time.NewTicker(time.Second / time.Duration(<rps>))
defer ticker.Stop()

for job := range jobs {
    <-ticker.C  // wait for tick = respect rate limit
    go process(job)
}

# Go: rate limiter - semaphore (limit concurrency)
sem := make(chan struct{}, <maxConcurrent>)

for _, item := range items {
    sem <- struct{}{}  // acquire
    go func(item Item) {
        defer func() { <-sem }()  // release
        process(item)
    }(item)
}
// drain semaphore to wait for all goroutines
for i := 0; i < cap(sem); i++ {
    sem <- struct{}{}
}

