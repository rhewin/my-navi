; ─────────────────────────────────────────────
; SLICE OPERATIONS
; ─────────────────────────────────────────────

% golang, go, slice, array, collection

# Go: slice - create and initialize
s := []int{1, 2, 3}
s := make([]int, <len>)           // len=cap, zero-valued
s := make([]int, <len>, <cap>)    // len with pre-allocated cap

# Go: slice - append
s = append(s, 1)
s = append(s, 1, 2, 3)
s = append(s, other...)  // spread another slice

# Go: slice - copy
dst := make([]int, len(src))
n := copy(dst, src)  // copies min(len(dst), len(src)) elements

# Go: slice - operations
s[<start>:<end>]          // sub-slice (shared backing array!)
s[<start>:]               // from start to end
s[:<end>]                 // from 0 to end
s[:]                      // full copy of view

# Go: slice - safe clone (avoid shared backing array)
clone := append([]int(nil), s...)
clone := slices.Clone(s)  // Go 1.21+

# Go: slice - contains (Go 1.21+)
slices.Contains(s, val)
idx := slices.Index(s, val)  // -1 if not found

# Go: slice - delete element at index
s = append(s[:i], s[i+1:]...)       // order-preserving
s[i] = s[len(s)-1]; s = s[:len(s)-1] // swap-delete (faster, no order)

# Go: slice - insert at index
s = append(s[:i+1], s[i:]...)
s[i] = val

# Go: slice - reverse
slices.Reverse(s)  // Go 1.21+ in-place
// manual:
for i, j := 0, len(s)-1; i < j; i, j = i+1, j-1 {
    s[i], s[j] = s[j], s[i]
}

# Go: filter slice - generic pattern (Go 1.18+ generics)
func Filter[T any](s []T, fn func(T) bool) []T {
    out := make([]T, 0, len(s))
    for _, v := range s {
        if fn(v) {
            out = append(out, v)
        }
    }
    return out
}
// Usage:
evens := Filter(nums, func(n int) bool { return n%2 == 0 })

# Go: filter slice - map (transform)
func Map[T, U any](s []T, fn func(T) U) []U {
    out := make([]U, len(s))
    for i, v := range s {
        out[i] = fn(v)
    }
    return out
}

# Go: filter slice - reduce
func Reduce[T, U any](s []T, init U, fn func(U, T) U) U {
    acc := init
    for _, v := range s {
        acc = fn(acc, v)
    }
    return acc
}

# Go: sort slice of structs
sort.Slice(items, func(i, j int) bool {
    return items[i].<field> < items[j].<field>
})

# Go: sort slice - stable sort
sort.SliceStable(items, func(i, j int) bool {
    return items[i].<field> < items[j].<field>
})

# Go: sort slice - built-in types
sort.Ints(s)
sort.Strings(s)
sort.Float64s(s)
slices.Sort(s)  // Go 1.21+ (generic)

# Go: deduplicate slice using map
func Unique[T comparable](s []T) []T {
    seen := make(map[T]struct{}, len(s))
    out := make([]T, 0, len(s))
    for _, v := range s {
        if _, ok := seen[v]; !ok {
            seen[v] = struct{}{}
            out = append(out, v)
        }
    }
    return out
}

# Go: chunk slice into batches
func Chunk[T any](s []T, size int) [][]T {
    var chunks [][]T
    for size < len(s) {
        s, chunks = s[size:], append(chunks, s[:size])
    }
    return append(chunks, s)
}

$ field: echo "Name Age Score CreatedAt"
$ len: echo "0 10 100"
$ cap: echo "10 100 1000"

; ─────────────────────────────────────────────
; MAP OPERATIONS
; ─────────────────────────────────────────────

% golang, go, map, hashmap, dictionary, collection

# Go: map - create and initialize
m := map[string]int{}
m := map[string]int{"a": 1, "b": 2}
m := make(map[string]int)
m := make(map[string]int, <hint>)  // pre-size hint (performance)

# Go: map - read / write / delete
m["key"] = 42           // write
v := m["key"]           // read (zero value if missing)
v, ok := m["key"]       // safe read; ok=false if missing
delete(m, "key")        // delete key

# Go: map - iterate (random order)
for k, v := range m {
    fmt.Printf("%s: %v\n", k, v)
}

# Go: map - sorted iteration
keys := make([]string, 0, len(m))
for k := range m {
    keys = append(keys, k)
}
sort.Strings(keys)
for _, k := range keys {
    fmt.Printf("%s: %v\n", k, m[k])
}

# Go: map - check key existence
if v, ok := m[key]; ok {
    fmt.Println("found:", v)
}

# Go: map - invert (swap keys and values)
inv := make(map[V]K, len(m))
for k, v := range m {
    inv[v] = k
}

# Go: map - merge two maps
for k, v := range src {
    dst[k] = v
}
maps.Copy(dst, src)  // Go 1.21+

# Go: map - clone
clone := maps.Clone(m)  // Go 1.21+

# Go: set pattern (map[T]struct{})
set := make(map[string]struct{})
set["item"] = struct{}{}
_, exists := set["item"]
delete(set, "item")

$ hint: echo "10 100 1000"

; ─────────────────────────────────────────────
; STRUCTS
; ─────────────────────────────────────────────

% golang, go, struct, type, oop

# Go: struct definition with tags
type <Name> struct {
    ID        int       `json:"id"         db:"id"`
    Name      string    `json:"name"       db:"name"        validate:"required"`
    Email     string    `json:"email"      db:"email"       validate:"required,email"`
    CreatedAt time.Time `json:"created_at" db:"created_at"`
    deleted   bool      // unexported field
}

# Go: struct embedding (composition over inheritance)
type Base struct {
    ID        int
    CreatedAt time.Time
    UpdatedAt time.Time
}

type User struct {
    Base              // embed - promotes fields & methods
    Name  string
    Email string
}

u := User{Name: "Alice"}
fmt.Println(u.ID)        // promoted from Base
fmt.Println(u.CreatedAt) // promoted from Base

# Go: struct methods - value vs pointer receiver
// Value receiver: does NOT modify original
func (u User) FullName() string {
    return u.FirstName + " " + u.LastName
}

// Pointer receiver: CAN modify original, preferred for mutation
func (u *User) Deactivate() {
    u.Active = false
}

# Go: constructor pattern
func New<Name>(name, email string) (*<Name>, error) {
    if name == "" {
        return nil, errors.New("name is required")
    }
    return &<Name>{
        Name:      name,
        Email:     email,
        CreatedAt: time.Now(),
    }, nil
}

# Go: struct with interface implementation
type Stringer interface {
    String() string
}

func (u User) String() string {
    return fmt.Sprintf("User{ID:%d Name:%s}", u.ID, u.Name)
}

# Go: struct comparison and zero value check
var u User                      // zero value
fmt.Println(u == (User{}))     // true if all fields comparable
fmt.Println(reflect.DeepEqual(u, User{})) // works for all types

# Go: anonymous struct (inline, one-off)
config := struct {
    Host string
    Port int
}{Host: "localhost", Port: 8080}

# Go: struct field tags - common patterns
// json: field name, omitempty, - (skip)
Field string `json:"field_name,omitempty"`
Skip  string `json:"-"`
// yaml, db, validate, form, env tags follow same pattern

$ Name: echo "User Order Product Config Service"

; ─────────────────────────────────────────────
; INTERFACES
; ─────────────────────────────────────────────

% golang, go, interface, polymorphism, duck-typing

# Go: interface definition
type <Name> interface {
    <Method>() <ReturnType>
    <Method2>(arg <ArgType>) (<ReturnType>, error)
}

# Go: interface - common stdlib interfaces
// io.Reader / io.Writer / io.Closer / io.ReadWriter
// fmt.Stringer  → String() string
// error         → Error() string
// sort.Interface → Len() int; Less(i,j int) bool; Swap(i,j int)

# Go: interface - check implementation at compile time
var _ io.Reader = (*MyReader)(nil)  // compile error if MyReader doesn't implement io.Reader

# Go: interface - empty interface / any
func printAny(v any) {
    fmt.Printf("type=%T value=%v\n", v, v)
}

# Go: interface composition
type ReadWriter interface {
    io.Reader
    io.Writer
}

# Go: interface - nil gotcha
var r io.Reader            // nil interface
var b *bytes.Buffer = nil  // typed nil
r = b                      // r is NOT nil! (has type info)
fmt.Println(r == nil)      // false — always check concrete type

