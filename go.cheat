; ─────────────────────────────────────────────
; STRING MANIPULATION
; ─────────────────────────────────────────────

% golang, go, strings, manipulation, text

# Go: substring
<string>[<start>:<end>]

# Go: strings - check contains / prefix / suffix
strings.Contains("<str>", "<substr>")
strings.HasPrefix("<str>", "<prefix>")
strings.HasSuffix("<str>", "<suffix>")

# Go: strings - split and join
parts := strings.Split("<str>", "<sep>")
joined := strings.Join(parts, "<sep>")
fields := strings.Fields("  foo bar  baz  ")  // split on any whitespace

# Go: strings - trim whitespace / characters
strings.TrimSpace("  hello  ")
strings.Trim("<str>", "<cutset>")
strings.TrimLeft("<str>", "<cutset>")
strings.TrimRight("<str>", "<cutset>")
strings.TrimPrefix("<str>", "<prefix>")
strings.TrimSuffix("<str>", "<suffix>")

# Go: strings - replace
strings.ReplaceAll("<str>", "<old>", "<new>")
strings.Replace("<str>", "<old>", "<new>", <n>)  // n=-1 for all

# Go: strings - case conversion
strings.ToUpper("<str>")
strings.ToLower("<str>")
strings.EqualFold("Go", "go")  // case-insensitive compare

# Go: strings - index / count
strings.Index("<str>", "<substr>")       // -1 if not found
strings.LastIndex("<str>", "<substr>")
strings.Count("<str>", "<substr>")
strings.ContainsRune("<str>", '<rune>')
strings.ContainsAny("<str>", "<chars>")  // any char in chars set

# Go: strings - repeat and pad
strings.Repeat("ab", 3)                        // "ababab"
fmt.Sprintf("%-10s|", "left")                  // left-padded  "left      |"
fmt.Sprintf("%10s|", "right")                  // right-padded "     right|"
fmt.Sprintf("%010d", 42)                        // zero-padded  "0000000042"

# Go: strings - builder (efficient concatenation)
var sb strings.Builder
for _, s := range <slice> {
    sb.WriteString(s)
    sb.WriteByte('\n')
}
result := sb.String()
sb.Reset() // reuse

# Go: strings - NewReader (io.Reader from string)
r := strings.NewReader("hello")
// use r as io.Reader anywhere

# Go: strings - cut (Go 1.18+)
before, after, found := strings.Cut("user@example.com", "@")
// before="user" after="example.com" found=true

