; ─────────────────────────────────────────────
; FILTER SLICE DATA
; ─────────────────────────────────────────────

% golang, go, slice, filter

# Go: filter slice - generic pattern (Go 1.18+ generics)
func Filter[T any](s []T, fn func(T) bool) []T {
    out := make([]T, 0, len(s))
    for _, v := range s {
        if fn(v) {
            out = append(out, v)
        }
    }
    return out
}
// Usage:
evens := Filter(nums, func(n int) bool { return n%2 == 0 })

# Go: filter slice - map (transform)
func Map[T, U any](s []T, fn func(T) U) []U {
    out := make([]U, len(s))
    for i, v := range s {
        out[i] = fn(v)
    }
    return out
}

# Go: filter slice - reduce
func Reduce[T, U any](s []T, init U, fn func(U, T) U) U {
    acc := init
    for _, v := range s {
        acc = fn(acc, v)
    }
    return acc
}

# Go: sort slice of structs
sort.Slice(items, func(i, j int) bool {
    return items[i].<field> < items[j].<field>
})

# Go: sort slice - stable sort
sort.SliceStable(items, func(i, j int) bool {
    return items[i].<field> < items[j].<field>
})

# Go: deduplicate slice using map
func Unique[T comparable](s []T) []T {
    seen := make(map[T]struct{}, len(s))
    out := make([]T, 0, len(s))
    for _, v := range s {
        if _, ok := seen[v]; !ok {
            seen[v] = struct{}{}
            out = append(out, v)
        }
    }
    return out
}

# Go: chunk slice into batches
func Chunk[T any](s []T, size int) [][]T {
    var chunks [][]T
    for size < len(s) {
        s, chunks = s[size:], append(chunks, s[:size])
    }
    return append(chunks, s)
}

