; ─────────────────────────────────────────────
; GENERICS (Go 1.18+)
; ─────────────────────────────────────────────

% golang, go, generics, type-parameter, constraints

# Go: generic function
func Map[T, U any](s []T, fn func(T) U) []U {
    out := make([]U, len(s))
    for i, v := range s {
        out[i] = fn(v)
    }
    return out
}

# Go: generic function with constraints
func Min[T constraints.Ordered](a, b T) T {
    if a < b {
        return a
    }
    return b
}

# Go: custom type constraint
type Number interface {
    int | int8 | int16 | int32 | int64 |
    float32 | float64
}

func Sum[T Number](s []T) T {
    var total T
    for _, v := range s {
        total += v
    }
    return total
}

# Go: generic struct
type Stack[T any] struct {
    items []T
}

func (s *Stack[T]) Push(v T)    { s.items = append(s.items, v) }
func (s *Stack[T]) Pop() (T, bool) {
    if len(s.items) == 0 {
        var zero T
        return zero, false
    }
    top := s.items[len(s.items)-1]
    s.items = s.items[:len(s.items)-1]
    return top, true
}

# Go: comparable constraint (usable as map key)
func Contains[T comparable](s []T, v T) bool {
    for _, item := range s {
        if item == v {
            return true
        }
    }
    return false
}

; ─────────────────────────────────────────────
; POINTERS
; ─────────────────────────────────────────────

% golang, go, pointer, reference, memory

# Go: pointer basics
x := 42
p := &x          // p is *int, holds address of x
fmt.Println(*p)  // dereference: 42
*p = 99          // modify through pointer; x is now 99

# Go: pointer to struct (preferred for mutation)
u := &User{Name: "Alice"}  // u is *User
u.Name = "Bob"             // auto-dereference (no need for (*u).Name)

# Go: new() - allocate zero value
p := new(int)    // *int pointing to 0
p := new(User)   // *User with zero-value fields

# Go: nil pointer guard
if p == nil {
    return errors.New("pointer is nil")
}

# Go: pointer to scalar (optional field pattern)
type Config struct {
    Timeout *int  // nil means "not set" vs 0
}
val := 30
cfg := Config{Timeout: &val}

# Go: helper - pointer to literal
func Ptr[T any](v T) *T { return &v }
// Usage: cfg.Timeout = Ptr(30)

; ─────────────────────────────────────────────
; ERROR HANDLING
; ─────────────────────────────────────────────

% golang, go, error, errors, handling

# Go: custom error type
type AppError struct {
    Code    int
    Message string
    Err     error
}

func (e *AppError) Error() string {
    return fmt.Sprintf("[%d] %s: %v", e.Code, e.Message, e.Err)
}

func (e *AppError) Unwrap() error { return e.Err }

// Usage:
return &AppError{Code: 404, Message: "user not found", Err: err}

# Go: sentinel errors (package-level)
var (
    ErrNotFound   = errors.New("not found")
    ErrUnauthorized = errors.New("unauthorized")
)

// Return:
return ErrNotFound

// Check:
if errors.Is(err, ErrNotFound) {
    // handle not found
}

# Go: error wrapping and unwrapping
err := fmt.Errorf("operation failed: %w", originalErr)

// Check error type
var appErr *AppError
if errors.As(err, &appErr) {
    fmt.Println("app error code:", appErr.Code)
}

// Check sentinel error (works through wrap chain)
if errors.Is(err, sql.ErrNoRows) {
    // handle not found
}

# Go: multiple return - idiomatic error handling
func divide(a, b float64) (float64, error) {
    if b == 0 {
        return 0, errors.New("division by zero")
    }
    return a / b, nil
}

result, err := divide(10, 0)
if err != nil {
    log.Printf("error: %v", err)
    return
}

# Go: panic and recover
func safeDiv(a, b int) (result int, err error) {
    defer func() {
        if r := recover(); r != nil {
            err = fmt.Errorf("recovered: %v", r)
        }
    }()
    return a / b, nil
}

# Go: join multiple errors (Go 1.20+)
err := errors.Join(err1, err2, err3)
// errors.Is and errors.As work on each wrapped error

; ─────────────────────────────────────────────
; GO CONCURRENCY
; ─────────────────────────────────────────────

% golang, go, concurrency, goroutine, channel, async

# Go: goroutine basics
go func() {
    // runs concurrently
    fmt.Println("in goroutine")
}()

# Go: channel - unbuffered (synchronous)
ch := make(chan <type>)
go func() { ch <- <value> }()
v := <-ch

# Go: channel - buffered (async up to cap)
ch := make(chan <type>, <bufsize>)
ch <- <value>   // non-blocking if buffer not full
v := <-ch

# Go: channel - close and drain
close(ch)
for v := range ch {} // drains until closed
v, ok := <-ch        // ok=false if closed and drained

# Go: WaitGroup - wait for goroutines to finish
var wg sync.WaitGroup
for _, item := range items {
    wg.Add(1)
    go func(item Item) {
        defer wg.Done()
        process(item)
    }(item)
}
wg.Wait()

# Go: select - multiplex channels
select {
case v := <-ch1:
    fmt.Println("from ch1:", v)
case v := <-ch2:
    fmt.Println("from ch2:", v)
case ch3 <- <value>:
    fmt.Println("sent to ch3")
case <-time.After(1 * time.Second):
    fmt.Println("timeout")
case <-ctx.Done():
    fmt.Println("context cancelled:", ctx.Err())
}

# Go: mutex - protect shared state
type SafeCounter struct {
    mu sync.Mutex
    v  map[string]int
}

func (c *SafeCounter) Inc(key string) {
    c.mu.Lock()
    defer c.mu.Unlock()
    c.v[key]++
}

func (c *SafeCounter) Value(key string) int {
    c.mu.RLock()
    defer c.mu.RUnlock()
    return c.v[key]
}

# Go: RWMutex (read-heavy workloads)
var mu sync.RWMutex
mu.RLock(); defer mu.RUnlock()  // concurrent reads OK
mu.Lock(); defer mu.Unlock()    // exclusive write

# Go: atomic operations (lock-free counters)
var counter int64
atomic.AddInt64(&counter, 1)
v := atomic.LoadInt64(&counter)
atomic.StoreInt64(&counter, 0)
atomic.CompareAndSwapInt64(&counter, old, new)

# Go: once - run initialization exactly once
var (
    instance *MyService
    once     sync.Once
)

func GetInstance() *MyService {
    once.Do(func() {
        instance = &MyService{}
    })
    return instance
}

# Go: context - cancellation and timeout
ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
defer cancel()

ctx, cancel = context.WithCancel(context.Background())
defer cancel()

// Pass context down the call chain
result, err := doWork(ctx)

# Go: context - value passing (use sparingly)
type ctxKey string
const userKey ctxKey = "user"
ctx = context.WithValue(ctx, userKey, user)
